rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── قواعد المستخدمين والمجموعات الفرعية ──────────────────────
    match /users/{uid} {
      // كل مستخدم يقرأ ويكتب بياناته في المستند الرئيسي
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // تشمل كل المجموعات الفرعية داخل حساب المستخدم (مثل: progress, study_plan, timer_state، إلخ)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // دالة التحقق من المشرف السوبر (يحق له إضافة المشرفين وتغيير الـ API)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'sqralqady63@gmail.com';
    }

    // دالة التحقق من صلاحية المشرف المساعد / المطور
    function isAdmin() {
      return request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.admin == true ||
        request.auth.token.email in ['admin@smartschool.com', 'developer@smartschool.com'] ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ─── المشرفون (Admins) ──────────────────────────────────────
    match /admins/{adminUid} {
      allow read: if request.auth != null && (request.auth.uid == adminUid || isSuperAdmin());
      allow write: if isSuperAdmin(); // السوبر فقط يضيف مشرفين
    }

    // ─── إعدادات النظام و AiConfig ──────────────────────────────
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin(); // السوبر فقط يغير الإعدادات
    }

    // ─── المواد الدراسية (للجميع قراءة، للمشرفين كتابة) ─────────
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();   // المشرفون والمطورون فقط

      // الدروس — الجميع يقرأ، المشرفون فقط يكتبون
      match /lessons/{lessonId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();

        // الأسئلة — الجميع يقرأ، المشرفون فقط يكتبون
        match /questions/{questionId} {
          allow read: if request.auth != null;
          allow write: if isAdmin();
        }
      }

      // الوحدات — الجميع يقرأ، المشرفون فقط يكتبون
      match /units/{unitId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();

        match /lessons/{lessonId} {
          allow read: if request.auth != null;
          allow write: if isAdmin();
        }
      }
    }

    // ─── الإشعارات (للجميع قراءة، للمشرفين كتابة) ─────────────────
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── الدرجات — للمستخدم نفسه فقط ────────────────────────────
    match /grades/{gradeId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
