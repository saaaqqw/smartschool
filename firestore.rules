rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── قواعد المستخدمين ─────────────────────────────────────
    match /users/{uid} {
      // كل مستخدم يقرأ ويكتب بياناته فقط
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // تقدم الدروس — القراءة والكتابة للمستخدم نفسه فقط
      match /progress/{subjectTitle} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // المهام اليومية — القراءة والكتابة للمستخدم نفسه فقط
      match /daily_tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // الخطة الدراسية — القراءة والكتابة للمستخدم نفسه فقط
      match /study_plan/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // جلسات الدراسة ووقت المؤقت — للمستخدم نفسه فقط
      match /study_sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // دالة التحقق من صلاحية المشرف / المطور
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email in ['aaasss@gmail.com', 'admin@smartschool.com', 'developer@smartschool.com'] ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ─── المشرفون (Admins) ──────────────────────────────────────
    match /admins/{adminUid} {
      allow read: if request.auth != null && (request.auth.uid == adminUid || isAdmin());
      allow write: if isAdmin();
    }

    // ─── إعدادات النظام و AiConfig ──────────────────────────────
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── المواد الدراسية (للجميع قراءة، للمشرفين كتابة) ─────────
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();   // المشرفون والمطورون فقط

      // الدروس — الجميع يقرأ، المشرفون فقط يكتبون
      match /lessons/{lessonId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();

        // الأسئلة — الجميع يقرأ، المشرفون فقط يكتبون
        match /questions/{questionId} {
          allow read: if request.auth != null;
          allow write: if isAdmin();
        }
      }

      // الوحدات — الجميع يقرأ، المشرفون فقط يكتبون
      match /units/{unitId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();

        match /lessons/{lessonId} {
          allow read: if request.auth != null;
          allow write: if isAdmin();
        }
      }
    }


    // ─── الدرجات — للمستخدم نفسه فقط ────────────────────────────
    match /grades/{gradeId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
